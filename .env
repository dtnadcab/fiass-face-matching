REDIS_URL="rediss://default:ASZxAAImcDJjMWQzOTZkNDVlNmQ0NjllODYxOGRjNTVkMDgwMGQ1OXAyOTg0MQ@flowing-titmouse-9841.upstash.io:6379"

# Match / search thresholds (dlib 128-d)
SEARCH_FACE_MATCH_THRESHOLD=0.90
SEARCH_HIGH_CONFIDENCE=0.93
ADD_FACE_REJECT_THRESHOLD=0.93
FACE_MATCH_MIN_MARGIN=0.04

# Registration pose envelope (degrees)
REG_MAX_YAW_DEGREES=30
REG_MAX_PITCH_DEGREES=15
REG_MAX_ROLL_DEGREES=10

# Registration image quality gates
REG_MIN_IMAGE_DIM=320
REG_MIN_FACE_SIZE=160
REG_MIN_BLUR_VARIANCE=80
REG_MIN_BRIGHTNESS=55
REG_MAX_BRIGHTNESS=210
REG_MIN_CONTRAST=20
REG_MIN_FACE_AREA_RATIO=0.08
REG_MAX_FACE_AREA_RATIO=0.80

# Passive anti-spoof (image-level heuristic)
REG_SPOOF_ENABLE=true
REG_SPOOF_MAX_MOIRE_RATIO=0.58
REG_SPOOF_MIN_COLOR_STD=8.0
REG_SPOOF_MAX_SPECULAR_RATIO=0.18

# Admin API key — required to call /face/force_delete and auto-heal endpoints
ADMIN_API_KEY=change-me-to-long-random-string

